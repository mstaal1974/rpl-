# RPL System v5 — multi-tenant — environment variables
# Copy to .env for local dev. Set these in Cloud Run for production.

# ── Required ──────────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-project-id
VERTEX_REGION=us-east5

# Secret used to sign JWTs. Generate with:  python -c "import secrets;print(secrets.token_urlsafe(48))"
# If unset in dev, the app auto-generates one but invalidates all tokens on restart.
AUTH_SECRET=

# One-time key used by POST /api/auth/bootstrap to create the first organisation.
# Set, run bootstrap once, then REMOVE it so no one can create rogue orgs.
BOOTSTRAP_KEY=

# JWT lifetime in hours (default 12)
AUTH_JWT_HOURS=12

# ── Storage / audit ───────────────────────────────────────────────────────────
FIRESTORE_DATABASE=(default)
BQ_DATASET=rpl_audit
BQ_TABLE=assessment_records
ASQA_RETENTION_YEARS=2

# ── Optional ──────────────────────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
DOCUMENT_AI_LOCATION=us
DOCAI_DEFAULT_PROCESSOR_ID=

# Google TTS Chirp 3 HD — restrict key to Cloud Text-to-Speech API
GOOGLE_TTS_API_KEY=

# Email notifications
SENDGRID_API_KEY=
SENDGRID_FROM=rpl@your-domain.com.au

# training.gov.au web-service credentials (for live unit import).
# Never hard-code these in source — set them here / in Cloud Run only.
TGA_USER=
TGA_PASS=

# CORS — leave blank to allow all origins WITHOUT credentials (Bearer-token API).
# Set a comma-separated allow-list to lock down and enable credentialed requests,
# e.g. ALLOWED_ORIGINS=https://portal.example.com,https://admin.example.com
ALLOWED_ORIGINS=

# Set this AFTER first deploy — it's the public URL invite links point at.
BASE_URL=

PORT=8080
